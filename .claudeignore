# =============================================================
# Control de Gastos Personales — .claudeignore
# Archivos que Claude no necesita leer para entender el proyecto
# =============================================================

# -------------------------------------------------------------
# Dependencias externas (código de terceros)
# -------------------------------------------------------------
node_modules/
frontend/node_modules/
.venv/
venv/
env/

# -------------------------------------------------------------
# Artefactos de build
# -------------------------------------------------------------
frontend/dist/
frontend/build/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/

# -------------------------------------------------------------
# Bases de datos (datos de usuario, no código)
# -------------------------------------------------------------
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
data/

# -------------------------------------------------------------
# Archivos de entorno y secretos
# -------------------------------------------------------------
.env
.env.local
.env.*.local
backend/.env
frontend/.env
frontend/.env.local

# -------------------------------------------------------------
# Logs y archivos temporales
# -------------------------------------------------------------
*.log
*.log.*
logs/
tmp/
temp/

# -------------------------------------------------------------
# Git internals
# -------------------------------------------------------------
.git/

# -------------------------------------------------------------
# IDEs
# -------------------------------------------------------------
.vscode/
.idea/

# -------------------------------------------------------------
# Sistema operativo
# -------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -------------------------------------------------------------
# Cache de herramientas
# -------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.eslintcache
*.tsbuildinfo
.turbo/
htmlcov/
.coverage
