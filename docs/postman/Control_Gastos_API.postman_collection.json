    {
      "name": "Auth",
      "description": "Endpoints de autenticación. No requieren Bearer Token.",
      "item": [
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\",\n  \"full_name\": \"Juan Pérez\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/auth/register",
              "host": ["{{base_url}}{{api_prefix}}"],
              "path": ["auth", "register"]
            },
            "description": "Registra un nuevo usuario. Devuelve access_token, refresh_token y datos del usuario. Los tokens se guardan automáticamente en variables de colección."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Respuesta contiene access_token\", function () {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res).to.have.property(\"access_token\");",
                  "});",
                  "",
                  "pm.test(\"Respuesta contiene refresh_token\", function () {",
                  "    const res = pm.response.json();",
                  "    pm.expect(res).to.have.property(\"refresh_token\");",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set(\"access_token\", res.access_token);",
                  "pm.collectionVariables.set(\"refresh_token\", res.refresh_token);"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
